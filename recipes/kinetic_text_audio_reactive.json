{
  "id": "kinetic_text_audio_reactive",
  "name": "Kinetic Text Audio Reactive",
  "description": "Texto cinético cuja luminosidade/saturação pulsa em sincronia com a banda de graves do áudio ao vivo. Offline-validated contra RecipeSchema; UNVERIFIED pending live cook-check em TouchDesigner.",
  "tags": ["text", "kinetic", "audio-reactive", "bass", "typography"],
  "difficulty": "intermediate",
  "td_version_min": "2022",
  "nodes": [
    {
      "name": "text1",
      "type": "textTOP",
      "parameters": {
        "text": "TDMCP",
        "fontsizex": 180,
        "alignx": "center",
        "aligny": "center"
      },
      "comment": "Texto base (kinetic_text)"
    },
    {
      "name": "transform1",
      "type": "transformTOP",
      "parameters": { "sx": 1.0, "sy": 1.0, "rotate": 0 },
      "comment": "Pulso de escala dirigido pelo audio reactive"
    },
    {
      "name": "audioin",
      "type": "audiodeviceinCHOP",
      "comment": "Captura de audio ao vivo"
    },
    {
      "name": "bass",
      "type": "audiobandeqCHOP",
      "parameters": { "loband": 60, "hiband": 200 },
      "comment": "Banda de graves (audio_reactive band)"
    },
    {
      "name": "analyze1",
      "type": "analyzeCHOP",
      "parameters": { "function": "rms" },
      "comment": "RMS da banda -> escalar reativo"
    },
    {
      "name": "level1",
      "type": "levelTOP",
      "parameters": { "brightness1": 1.0, "gamma1": 1.0 },
      "comment": "Brilho modulado pelo RMS via parametro exposto"
    },
    { "name": "out1", "type": "nullTOP", "comment": "TOP de saida final" }
  ],
  "connections": [
    { "from": "text1", "to": "transform1" },
    { "from": "transform1", "to": "level1" },
    { "from": "level1", "to": "out1" },
    { "from": "audioin", "to": "bass" },
    { "from": "bass", "to": "analyze1" }
  ],
  "parameters": [
    {
      "name": "text",
      "node": "text1",
      "param": "text",
      "value": "TDMCP",
      "label": "Text"
    },
    {
      "name": "font_size",
      "node": "text1",
      "param": "fontsizex",
      "value": 180,
      "min": 24,
      "max": 480,
      "label": "Font Size"
    },
    {
      "name": "bass_low",
      "node": "bass",
      "param": "loband",
      "value": 60,
      "min": 20,
      "max": 500,
      "label": "Bass Low (Hz)"
    },
    {
      "name": "bass_high",
      "node": "bass",
      "param": "hiband",
      "value": 200,
      "min": 60,
      "max": 1000,
      "label": "Bass High (Hz)"
    },
    {
      "name": "pulse_gain",
      "node": "level1",
      "param": "brightness1",
      "value": 1.0,
      "min": 0,
      "max": 4,
      "label": "Pulse Gain",
      "description": "Liga a um expression como op('analyze1')['chan1']*2 para pulsar com o grave."
    }
  ],
  "preview_description": "A palavra 'TDMCP' grande e centralizada que respira/brilha no compasso dos graves da musica."
}
