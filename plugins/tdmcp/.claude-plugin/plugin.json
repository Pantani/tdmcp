{
  "name": "tdmcp",
  "version": "0.12.0",
  "description": "Connect Claude Code to TouchDesigner through the tdmcp Model Context Protocol server.",
  "author": {
    "name": "Pantani",
    "url": "https://github.com/Pantani/tdmcp"
  },
  "homepage": "https://pantani.github.io/tdmcp/",
  "repository": "https://github.com/Pantani/tdmcp",
  "license": "MIT",
  "keywords": [
    "touchdesigner",
    "mcp",
    "model-context-protocol",
    "creative-coding",
    "generative-art",
    "vj"
  ],
  "mcpServers": {
    "tdmcp": {
      "command": "npx",
      "args": ["--yes", "--package=@dpantani/tdmcp@0.12.0", "tdmcp"],
      "env": {
        "TDMCP_TRANSPORT": "stdio",
        "TDMCP_RAW_PYTHON": "off",
        "TDMCP_TOOL_PROFILE": "safe"
      }
    }
  }
}
